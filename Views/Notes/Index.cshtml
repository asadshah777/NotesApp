@model List<Note>


<main class="mt-2 d-flex justify-content-between">
    <div class="mt-2">
        <h2>Showing you all Notes</h2>
    </div>
    <a asp-controller="Notes" asp-action="Create" class="btn btn-danger" style="padding-top:14px;width: 200px;">
        Create a note
    </a>

</main>
<main class="mt-5 d-flex flex-row gap-3">
    @if(Model.Count == 0){
        <h3 class="mt-3">No Notes to show</h3>
    }else{
         @foreach(Note note in Model){
        <div class="w-25 border shadow-sm rounded-1 p-3">
            <h3>@note.Content</h3>
            <span class="mt-2">Last Modified:@note.UpdatedAt.ToShortDateString()</span> <br>
            <span class="">Created: @note.CreatedAt.ToShortDateString()</span>
            <div class="mt-3 d-flex flex-row align-items-center gap-2">
                <a asp-route-id="@note.Id" asp-controller="Notes" asp-action="Edit" class="btn btn-primary">Edit</a>
                <a onclick="confirmationDialog();" asp-route-id="@note.Id" asp-controller="Notes" asp-action="Delete" class="btn btn-danger">Delete</a>
            </div>
        </div>
    }
    }
</main>

<script>
    const confirmationDialog = ()=>{
        alert("Successfully deleted!");
    }
</script>